---
import '../styles/main.css';

const title = 'Mi App';
const description = 'Tu aplicación favorita';
const themeColor = '#6c63ff';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content={themeColor} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%236c63ff'/%3E%3Ctext x='16' y='21' font-family='Arial' font-size='12' font-weight='bold' fill='white' text-anchor='middle'%3EM%3C/text%3E%3C/svg%3E" />
    <link rel="apple-touch-icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='20' fill='%236c63ff'/%3E%3Ctext x='50' y='62' font-family='Arial' font-size='40' font-weight='bold' fill='white' text-anchor='middle'%3EMi%3C/text%3E%3Ctext x='50' y='82' font-family='Arial' font-size='18' fill='rgba(255,255,255,0.8)' text-anchor='middle'%3EApp%3C/text%3E%3C/svg%3E" />
    <link rel="manifest" href={'data:application/json,' + encodeURIComponent(JSON.stringify({
      name: title,
      short_name: title,
      start_url: '/',
      display: 'standalone',
      background_color: '#0f0f1a',
      theme_color: themeColor,
      icons: [{
        src: 'data:image/svg+xml,%3Csvg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"%3E%3Crect width="100" height="100" rx="20" fill="%236c63ff"/%3E%3Ctext x="50" y="62" font-family="Arial" font-size="40" font-weight="bold" fill="white" text-anchor="middle"%3EMi%3C/text%3E%3Ctext x="50" y="82" font-family="Arial" font-size="18" fill="rgba(255,255,255,0.8)" text-anchor="middle"%3EApp%3C/text%3E%3C/svg%3E',
        sizes: '192x192',
        type: 'image/svg+xml'
      }]
    }))} />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { -webkit-text-size-adjust: 100%; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
        overscroll-behavior: none;
        -webkit-tap-highlight-color: transparent;
        padding-top: env(safe-area-inset-top);
        padding-bottom: env(safe-area-inset-bottom);
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
